{
  // Visit https://aka.ms/tsconfig to read more about this file
"compilerOptions": {
  "target": "ESNext",
  "module": "CommonJS",
  "moduleResolution": "bundler",
  "types": ["node", "@playwright/test"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["tests", "steps", "pages", "playwright.config.ts"]
}
